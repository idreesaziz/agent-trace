{
  "project": {
    "name": "agent-trace",
    "purpose": "With the explosion of agent frameworks, developers struggle to debug where a swarm went wrong or why a specific tool was called. AgentTrace is a lightweight local server that ingests standardized logs from any agent framework and visualizes the reasoning chain, tool calls, and state transitions in a clean UI. It allows developers to step through an agent's thought process retrospectively across different libraries.",
    "tech_stack": [
      "TypeScript",
      "Python"
    ],
    "roadmap": [
      {
        "phase": 1,
        "title": "Standardized Schema & Python SDK",
        "description": "Define the universal JSON schema for agent events (reasoning, tool calls, state changes). Build a lightweight, non-blocking Python SDK to structure and emit these events.",
        "status": "in-progress"
      },
      {
        "phase": 2,
        "title": "Local Ingestion Server",
        "description": "Develop a lightweight TypeScript local server utilizing a local SQLite database to ingest, validate, and persist trace payloads from the Python SDK.",
        "status": "not-started"
      },
      {
        "phase": 3,
        "title": "Frontend Skeleton & Trace List",
        "description": "Set up the React/TypeScript frontend. Build the main dashboard to list ingested agent runs, display high-level metadata, and provide routing to individual trace views.",
        "status": "not-started"
      },
      {
        "phase": 4,
        "title": "Reasoning Chain & Tool Call Visualization",
        "description": "Implement a tree or waterfall visualization for individual traces. Render LLM prompts, reasoning steps, and tool execution inputs/outputs in a clear, collapsible interface.",
        "status": "not-started"
      },
      {
        "phase": 5,
        "title": "State Transitions & Step-Through Debugger",
        "description": "Add an interactive timeline scrubber to the UI. Allow developers to step forward and backward through a run to view state diffs and context windows at any exact moment.",
        "status": "not-started"
      },
      {
        "phase": 6,
        "title": "Drop-in Framework Integrations",
        "description": "Build middleware and callback handlers in Python to automatically capture and format traces from popular frameworks (LangChain, CrewAI, AutoGen) with minimal manual instrumentation.",
        "status": "not-started"
      },
      {
        "phase": 7,
        "title": "Advanced Search, Export & UX Polish",
        "description": "Implement full-text search across agent logs, filtering by tool/outcome, and UX polish. Add import/export functionality so developers can share trace files for collaborative debugging.",
        "status": "not-started"
      }
    ],
    "current_phase": 1
  },
